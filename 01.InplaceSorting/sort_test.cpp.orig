#include <gtest/gtest.h>

// А вот тут collvalue.h не надо, берите просто инты
#include "sorting.h"

// Но проверьте, что сортировки таки работают...

TEST(InsertionSort, Array)
{
        std::vector<int> array = {6, 7, 11, 7, 6, -1125, 236325, 0, 0, 0, -1125, 2};
	std::vector<int> sorted_array = {-1125, -1125, 0, 0, 0, 2, 6, 6, 7, 7, 11, 236325};
	insertion_sort(array.begin(), array.end());
	EXPECT_EQ(array, sorted_array);
}

TEST(QuickSort, Array)
{
        std::vector<int> array = {6, 7, 11, 7, 6, -1125, 236325, 0, 0, 0, -1125, 2};
        std::vector<int> sorted_array = {-1125, -1125, 0, 0, 0, 2, 6, 6, 7, 7, 11, 236325};
        quick_sort(array.begin(), array.end());
        EXPECT_EQ(array, sorted_array);
}

TEST(InsertionSort, Empty_array)
{
        std::vector<int> array = {};
        std::vector<int> sorted_array = {};
        insertion_sort(array.begin(), array.end());
        EXPECT_EQ(array, sorted_array);
}

TEST(QuickSort, Empty_array)
{
        std::vector<int> array = {};
        std::vector<int> sorted_array = {};
        quick_sort(array.begin(), array.end());
        EXPECT_EQ(array, sorted_array);
}

TEST(InsertionSort, Sorted_array)
{
        std::vector<int> array = {1, 3, 3, 7, 135135};
        std::vector<int> sorted_array = {1, 3, 3, 7, 135135};
        insertion_sort(array.begin(), array.end());
        EXPECT_EQ(array, sorted_array);
}

TEST(QuickSort, Sorted_array)
{
        std::vector<int> array = {1, 3, 3, 7, 135135};
        std::vector<int> sorted_array = {1, 3, 3, 7, 135135};
        quick_sort(array.begin(), array.end());
        EXPECT_EQ(array, sorted_array);
}

TEST(InsertionSort, Sorted_back_array)
{
        std::vector<int> array = {11, 9, 5, -8, -10};
        std::vector<int> sorted_array = {-10, -8, 5, 9, 11};
        insertion_sort(array.begin(), array.end());
        EXPECT_EQ(array, sorted_array);
}

TEST(QuickSort, Sorted_back_array)
{
        std::vector<int> array = {11, 9, 5, -8, -10};
        std::vector<int> sorted_array = {-10, -8, 5, 9, 11};
        quick_sort(array.begin(), array.end());
        EXPECT_EQ(array, sorted_array);
}

